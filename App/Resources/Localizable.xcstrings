    },
    "A compact 4-billion-parameter model from the Qwen 3 family with stronger reasoning than 3B. Recommended default for devices with 8 GB of RAM.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A compact 4-billion-parameter model from the Qwen 3 family with stronger reasoning than 3B. Recommended default for devices with 8 GB of RAM."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Компактная модель на 4 миллиарда параметров из семейства Qwen 3 — рассуждает заметно сильнее 3B. Рекомендуется для устройств с 8 ГБ ОЗУ."
          }
        }
      }
    },
    "A couple of permissions": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A couple of permissions"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пара разрешений"
          }
        }
      }
    },
    "A few common questions. If yours isn't here, write to us — every email is read by a human.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A few common questions. If yours isn't here, write to us — every email is read by a human."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Несколько частых вопросов. Если вашего здесь нет — напишите нам, каждое письмо читает живой человек."
          }
        }
      }
    },
    "A larger 8-billion-parameter model from Qwen 3 for noticeably deeper reflections and more nuanced writing. Needs a device with at least 12 GB of RAM.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A larger 8-billion-parameter model from Qwen 3 for noticeably deeper reflections and more nuanced writing. Needs a device with at least 12 GB of RAM."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Более крупная модель Qwen 3 на 8 миллиардов параметров — для глубже проработанных рефлексий. Нужно устройство с 12 ГБ ОЗУ или больше."
          }
        }
      }
    },
    "A private conversation with your journal": {
      "extractionState": "manual",
      "localizations": {
        "en": {
