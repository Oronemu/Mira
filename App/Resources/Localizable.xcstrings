    "Mira drafts a reflection from the last week of entries. It runs in the background on Sunday evenings — or trigger one here.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira drafts a reflection from the last week of entries. It runs in the background on Sunday evenings — or trigger one here."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira создаёт размышление по записям за последнюю неделю. Это происходит в фоне вечером в воскресенье — или запустите вручную здесь."
          }
        }
      }
    },
    "Mira is a private iOS journal. Your entries stay on your device — an on-device language model helps you reflect without sending your writing anywhere. Optional iCloud sync is end-to-end encrypted.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira is a private iOS journal. Your entries stay on your device — an on-device language model helps you reflect without sending your writing anywhere. Optional iCloud sync is end-to-end encrypted."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira — приватный дневник для iOS. Записи остаются на устройстве, а on-device языковая модель помогает размышлять, не отправляя ваш текст никуда. Опциональная iCloud-синхронизация защищена end-to-end шифрованием."
          }
        }
      }
    },
    "Mira is locked": {
      "extractionState": "stale",
      "localizations": {
        "en": {
