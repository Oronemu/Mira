    "A compact 4-billion-parameter model from the Qwen 3 family with stronger reasoning than 3B. Recommended default for devices with 8 GB of RAM.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A compact 4-billion-parameter model from the Qwen 3 family with stronger reasoning than 3B. Recommended default for devices with 8 GB of RAM."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Компактная модель на 4 миллиарда параметров из семейства Qwen 3 — рассуждает заметно сильнее 3B. Рекомендуется для устройств с 8 ГБ ОЗУ."
          }
        }
      }
    },
    "A couple of permissions": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A couple of permissions"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пара разрешений"
          }
        }
      }
    },
    "A larger 8-billion-parameter model from Qwen 3 for noticeably deeper reflections and more nuanced writing. Needs a device with at least 12 GB of RAM.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A larger 8-billion-parameter model from Qwen 3 for noticeably deeper reflections and more nuanced writing. Needs a device with at least 12 GB of RAM."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Более крупная модель Qwen 3 на 8 миллиардов параметров — для глубже проработанных рефлексий. Нужно устройство с 12 ГБ ОЗУ или больше."
          }
        }
      }
    },
    "A private conversation with your journal": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A private conversation with your journal"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тихий разговор наедине с твоим дневником"
          }
        }
      }
    },
    "A private journal where you write what you're going through, track your mood day by day, and let an on-device AI help you reflect — your words never leave the phone.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A private journal where you write what you're going through, track your mood day by day, and let an on-device AI help you reflect — your words never leave the phone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Личный дневник: записывай, что переживаешь, отслеживай настроение день за днём, а ИИ прямо на устройстве поможет разобраться в мыслях — твои слова не покидают телефон."
          }
        }
      }
    },
    "A quiet conversation with what you've written": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A quiet conversation with what you've written"
