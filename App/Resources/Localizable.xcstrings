        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я не терапевт и не врач. Мои ответы могут быть ошибочными — не воспринимай их как профессиональный совет. Если ты в кризисе, обратись к квалифицированному специалисту или в службу экстренной помощи."
          }
        }
      }
    },
