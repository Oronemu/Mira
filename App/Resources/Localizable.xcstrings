        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тихий разговор с тем, что ты уже написал"
          }
        }
      }
    },
    "A small on-device model runs locally for writing prompts and reflections. Remote providers are opt-in and use your own API key.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A small on-device model runs locally for writing prompts and reflections. Remote providers are opt-in and use your own API key."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Небольшая модель работает прямо на устройстве — для идей и размышлений. Удалённые провайдеры подключаются по желанию и используют ваш API-ключ."
          }
        }
      }
    },
